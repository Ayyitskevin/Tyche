# Production environment for docker-compose.prod.yml. Copy to .env.prod at the
# repo root and fill in. scripts/deploy.sh creates it from this template and
# generates the session secret for you on first run.

# --- Required ---
TYCHE_DOMAIN=terminal.example.com
# Signs session cookies. Generate: openssl rand -base64 32
TYCHE_SESSION_SECRET=

# --- Recommended ---
# Let's Encrypt expiry/problem notices go here.
TYCHE_ACME_EMAIL=you@example.com
# This registration becomes the admin (otherwise: the first account).
TYCHE_ADMIN_EMAIL=you@example.com
# open (anyone can start a trial) or closed (private beta after the founder).
TYCHE_SIGNUPS=open

# --- Billing (docs/BILLING.md) ---
# none = accounts, no paywall (soft launch). stripe = production billing.
# mock is for LOCAL DEV ONLY — its checkout grants pro without payment.
TYCHE_BILLING=none
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
TYCHE_PRICE_MONTHLY=29

# --- Live data (optional, bring-your-own-key; mock needs nothing) ---
TYCHE_PROVIDERS=mock
SEC_EDGAR_USER_AGENT=
FRED_API_KEY=

# --- Transactional email (password reset) ---
# `console` (default) LOGS reset mail to the container log instead of sending it
# (and redacts the token in hosted mode) — fine for a soft launch, but users
# can't complete a reset. Set `http` + a webhook to actually deliver mail.
TYCHE_EMAIL_SINK=console
TYCHE_EMAIL_WEBHOOK_URL=
TYCHE_EMAIL_WEBHOOK_TOKEN=
# Most providers require a From/sender; only a relay that sets its own can omit it.
TYCHE_EMAIL_FROM="Tyche <no-reply@terminal.example.com>"
