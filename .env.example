# =============================================================================
# Tyche environment configuration (example)
# Copy to `.env` for local overrides. Tyche runs FULLY in mock mode with NO keys.
# Live/paid providers are OPTIONAL adapters behind capability flags.
# =============================================================================

# --- API server ---
API_HOST=127.0.0.1
API_PORT=4010
# CORS origin allowed to call the API. Governs BOTH the REST API and the SSE stream.
WEB_ORIGIN=http://localhost:5173

# --- Web client ---
# Base URL the browser uses to reach the API.
VITE_API_BASE_URL=http://localhost:4010

# --- Persistence ---
# Directory for the local JSON persistence store (users, workspaces, watchlists...).
TYCHE_DATA_DIR=./data
# Persistence backend: `file` (default, zero-config JSON document) or `sqlite`
# (durable, indexed local SQLite via Node's built-in node:sqlite — no native build).
# If sqlite fails to initialize, the API falls back to the file store.
TYCHE_PERSISTENCE=file
# SQLite database path (only used when TYCHE_PERSISTENCE=sqlite). Defaults to
# <TYCHE_DATA_DIR>/tyche.db.
# TYCHE_SQLITE_PATH=./data/tyche.db

# Auth rate-limiter backend: `memory` (default, node-local) or `sqlite` (a shared
# rate_hits DB so every API node behind a load balancer enforces ONE credential
# budget instead of limit×nodes). Use sqlite on a shared volume for multi-node
# deployments; falls back to memory (with a warning) if the DB can't be opened.
TYCHE_RATE_LIMIT_STORE=memory
# Path for the shared rate-limit DB (only used when TYCHE_RATE_LIMIT_STORE=sqlite).
# Defaults to <TYCHE_DATA_DIR>/ratelimit.db.
# TYCHE_RATE_LIMIT_SQLITE_PATH=./data/ratelimit.db

# --- Provider selection ---
# Comma-separated list of providers to enable. `mock` is always available and is
# the default. Enabling others requires the corresponding adapter + entitlements.
# `binance` (keyless public crypto data) routes pairs like BTC-USDT to the live
# venue while everything else stays with the other providers — list it FIRST:
# `frankfurter` (keyless ECB FX rates) serves ISO pairs like EUR-USD the same way.
# `dexscreener` (keyless on-chain DEX pools) serves only the DEX command's data.
# e.g. TYCHE_PROVIDERS=binance,frankfurter,dexscreener,mock
#  or  binance,frankfurter,dexscreener,secedgar,fred,mock
TYCHE_PROVIDERS=mock

# --- Plugins (provider SDK) ---
# Comma-separated module specifiers for operator-installed provider plugins.
# Local/installed modules only — Tyche never downloads code. Each is conformance-
# gated before it can serve data; status is at GET /api/plugins. See docs/PLUGINS.md.
# e.g. TYCHE_PLUGINS=@acme/tyche-quotes,./local-plugins/my-adapter
TYCHE_PLUGINS=

# --- SEC EDGAR (filings) — public, no key, but a descriptive User-Agent is REQUIRED ---
# Enable with TYCHE_PROVIDERS=secedgar. The SEC fair-access policy requires a
# descriptive User-Agent identifying you (name + contact email), e.g.:
#   SEC_EDGAR_USER_AGENT="Your Name your@email.com"
# Serves real filings AND XBRL fundamentals (FA) for US issuers; leave blank to
# keep both served by the deterministic mock provider.
SEC_EDGAR_USER_AGENT=

# --- FRED (economicSeries) — public, requires a FREE API key ---
# Enable with TYCHE_PROVIDERS=fred. Get a free key at
# https://fred.stlouisfed.org/docs/api/api_key.html. The key is sent only as a
# request parameter and is never written into provenance. Leave blank to keep
# economic series served by the deterministic mock provider.
FRED_API_KEY=

# --- Reserved for future provider adapters (NOT yet read by the API) ---
# Referenced by the disabled scaffolds in packages/data-adapters/src/stubs/*;
# setting them today is a no-op until their adapters ship. See DATA_PROVIDERS.md.
YAHOO_ENABLED=false
CCXT_EXCHANGE=

# --- AI copilot (optional) ---
# When unset, the AI panel runs in deterministic mock mode (no network).
# Model configuration is isolated; never commit real keys.
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=

# --- Observability ---
# Version string reported by GET /api/health (helps identify the deployed build).
# Defaults to the API package version; set it to your release tag / git SHA.
# TYCHE_VERSION=v0.3.0

# --- Audit log ---
# Where mutating/sensitive actions are recorded. `console` (default) logs a
# structured line to stdout; `file` also appends durable JSON lines to a log a
# self-hoster can retain. Recent events are viewable in SETTINGS and at GET /api/audit.
# One of: console (default) | file | http (stream to an external SIEM/collector).
TYCHE_AUDIT_SINK=console
# Path for the file sink (only used when TYCHE_AUDIT_SINK=file). Defaults to
# <TYCHE_DATA_DIR>/audit.log.
# TYCHE_AUDIT_FILE=./data/audit.log
# Webhook for the http sink (required when TYCHE_AUDIT_SINK=http; each event is
# POSTed as JSON, fire-and-forget). Optional bearer token for the endpoint.
# TYCHE_AUDIT_WEBHOOK_URL=https://siem.example.com/ingest
# TYCHE_AUDIT_WEBHOOK_TOKEN=

# --- Transactional email (hosted mode — password reset, etc.) ---
# Tyche bundles NO email provider — bring your own, like market-data keys.
# `console` (default) logs each message instead of sending it, so password reset
# is exercisable in dev with zero setup (in dev the reset link is printed; in
# hosted mode the token is REDACTED from the log). `http` POSTs each message as
# JSON `{ to, subject, text[, from] }` to your own endpoint — a transactional
# provider's HTTP API, or a thin SMTP relay.
TYCHE_EMAIL_SINK=console
# Required when TYCHE_EMAIL_SINK=http (else it degrades back to console logging,
# with a loud boot warning in hosted mode):
# TYCHE_EMAIL_WEBHOOK_URL=https://api.youremailprovider.com/v1/send
# Optional bearer token sent as `Authorization: Bearer <token>` on the webhook.
# TYCHE_EMAIL_WEBHOOK_TOKEN=
# From address in the webhook payload — required by most transactional providers
# when POSTing directly to their API; optional only if your relay sets the sender.
# Quote it: the angle brackets are shell redirection if you `source` this file.
# TYCHE_EMAIL_FROM="Tyche <no-reply@terminal.example.com>"

# --- Security (optional, OFF by default for local dev) ---
# When true, the API requires a bearer token (TYCHE_AUTH_TOKEN) on mutating routes.
TYCHE_AUTH_ENABLED=false
TYCHE_AUTH_TOKEN=

# --- Same-origin serving (optional) ---
# Point at a built web app (e.g. ./apps/web/dist) and the API serves it with an
# SPA fallback — one process, one port. Used by `pnpm demo` and the Docker image.
# TYCHE_SERVE_WEB=./apps/web/dist

# --- Hosted mode (multi-user SaaS, optional — default is single-user selfhost) ---
# `hosted` turns on accounts: register/login (scrypt-hashed passwords), 30-day
# httpOnly cookie sessions, and hard per-user data isolation (each account gets
# its own store under <TYCHE_DATA_DIR>/users/<id>). Self-host behavior is
# completely unchanged unless you opt in.
TYCHE_MODE=selfhost
# Read-only PUBLIC DEMO: blocks every persistence write (workspaces, notes,
# alerts, ...) with a 403 so a shared, no-signup instance can't be clobbered.
# Reads, streams, market data, the screener and the AI copilot still work.
# One-command public demo: docker run -e TYCHE_DEMO=true -p 4010:4010 ghcr.io/ayyitskevin/tyche:latest
TYCHE_DEMO=false
# REQUIRED in hosted mode (>= 16 chars); signs session tokens. Generate one:
#   openssl rand -base64 32
TYCHE_SESSION_SECRET=
# Number of trusted reverse-proxy hops in front of the API. request.ip and
# X-Forwarded-* are resolved from exactly this many hops, so a client cannot
# spoof its IP (and bypass auth rate limiting) via X-Forwarded-For. Default 1
# matches the shipped single-Caddy deploy (its Caddyfile OVERWRITES XFF with the
# direct client). Running a CDN/proxy IN FRONT of Caddy needs more than raising
# this — the edge Caddy must also preserve the upstream's forwarded client (see
# deploy/Caddyfile), else per-PoP users share one rate-limit bucket. Hosted only.
TYCHE_TRUST_PROXY_HOPS=1
# `open` (default) lets anyone register (14-day trial). `closed` blocks new
# sign-ups once the first (founder/admin) account exists.
TYCHE_SIGNUPS=open
# This email is granted admin on registration (otherwise: the first account).
TYCHE_ADMIN_EMAIL=
# Max seats (accounts + outstanding invites) on a closed-signup team instance.
# Unset/blank or 0 = unlimited. Admins provision seats via ADMIN → invite.
TYCHE_SEATS=

# --- Billing (hosted mode only; see docs/BILLING.md) ---
# `none` (default): accounts, no paywall. `stripe`: production billing.
# `mock`: DEV/TEST ONLY — instant fake checkout that grants pro without
# payment (full trial→pro loop with no Stripe account); must be set explicitly.
TYCHE_BILLING=none
# Required when TYCHE_BILLING=stripe (the API refuses to boot without them):
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Optional second (annual) price. When set, ACCOUNT offers a yearly plan; unset,
# an annual checkout falls back to monthly. Price it at ~10x monthly for "2 months free".
STRIPE_PRICE_ID_ANNUAL=
STRIPE_WEBHOOK_SECRET=
# Public base URL for checkout/portal redirects (defaults to WEB_ORIGIN).
# TYCHE_PUBLIC_URL=https://terminal.example.com
# Monthly price in whole currency units — display + the ADMIN dashboard's MRR
# readout only (Stripe's price object is the billing source of truth).
TYCHE_PRICE_MONTHLY=29
